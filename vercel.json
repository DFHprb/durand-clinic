{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|svg|gif|ico|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],

  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "durandhealth.com" }], "destination": "https://durand.clinic/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.durandhealth.com" }], "destination": "https://durand.clinic/$1", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/paramedical", "destination": "/treatment-services", "permanent": true },
    { "source": "/paramedical.html", "destination": "/treatment-services", "permanent": true },
    { "source": "/residential", "destination": "/renewal", "permanent": true },
    { "source": "/residential.html", "destination": "/renewal", "permanent": true },
    { "source": "/residential-fr", "destination": "/renewal-fr", "permanent": true },
    { "source": "/residential-de", "destination": "/renewal-de", "permanent": true },
    { "source": "/residential-it", "destination": "/renewal-it", "permanent": true },
    { "source": "/residential-nl", "destination": "/renewal-nl", "permanent": true },
    { "source": "/residential-zh", "destination": "/renewal-zh", "permanent": true },
    { "source": "/residential-hi", "destination": "/renewal-hi", "permanent": true },
    { "source": "/residential-ar", "destination": "/renewal-ar", "permanent": true }
  ]
}
